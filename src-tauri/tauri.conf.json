{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "TechniDAQ",
  "version": "0.1.0",
  "identifier": "com.technicatgroup.technidaq",
  "build": {
    "beforeDevCommand":   "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl":             "http://localhost:1420",
    "frontendDist":       "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label":           "main",
        "title":           "TechniDAQ — Technicat Group",
        "width":           1280,
        "height":          800,
        "minWidth":        900,
        "minHeight":       600,
        "resizable":       true,
        "fullscreen":      false,
        "decorations":     true,
        "visible":         true
      }
    ]
  },
  "bundle": {
    "active":          true,
    "targets":         "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources":       ["profiles.json"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxNTQ1Qzc2NTc5OTc3RDEKUldUUmQ1bFhkbHhVOFRieEVsbUJ5eXBLd2VIWFUrYXI1TmZzdnVtamFUQlo4bGd4c0ZkWXpTS04K",
      "endpoints": [
        "https://github.com/Joe-Sfeir/TechniDAQ/releases/latest/download/latest.json"
      ]
    }
  }
}